{
  "name": "f1-box-box",
  "version": "1.0.1",
  "description": "F1 box box themed loading animation — car in, wheel gun, out. Injected SVG + CSS, zero dependencies.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "animation",
    "loading",
    "f1",
    "spinner",
    "ui",
    "zero-dependency"
  ],
  "sideEffects": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/everything-frontend/f1-box-box"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
